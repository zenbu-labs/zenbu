# Copy to .env.release and fill in values. .env.release is gitignored.
# Sourced by scripts/release-local.sh — matches the secrets the GitHub workflow uses.

# ---- macOS code signing ----
# CSC_LINK: path to your Developer ID Application .p12 (local) OR base64 of it (CI).
# Locally a plain file path is easiest.
CSC_LINK=/absolute/path/to/developer-id.p12
CSC_KEY_PASSWORD=the-password-you-set-when-exporting-the-p12

# ---- macOS notarization (app-specific password method) ----
APPLE_ID=your-apple-id@example.com
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPLE_TEAM_ID=ABCDE12345

# ---- Publishing ----
# Set to "always" to push to GitHub Releases (requires GH_TOKEN).
# PUBLISH=always
# GH_TOKEN=ghp_xxx   # a PAT with `repo` scope for RobPruzan/zenbu
