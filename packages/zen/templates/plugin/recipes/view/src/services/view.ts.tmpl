import path from "node:path"
import { fileURLToPath } from "node:url"
import { Service, runtime } from "#zenbu/init/src/main/runtime"
import { ViewRegistryService } from "#zenbu/init/src/main/services/view-registry"

/**
 * Starts a Vite dev server for this plugin's view and registers it under
 * scope "{{name}}". The orchestrator loads it in an iframe and it
 * connects back over WebSocket for RPC + reactive DB.
 */
export class {{PascalName}}ViewService extends Service {
  static key = "{{name}}-view"
  static deps = { viewRegistry: ViewRegistryService }
  declare ctx: { viewRegistry: ViewRegistryService }

  evaluate() {
    this.setup("register-view", () => {
      const serviceDir = path.dirname(fileURLToPath(import.meta.url))
      const viewRoot = path.resolve(serviceDir, "..", "view")
      const configFile = path.resolve(serviceDir, "..", "..", "vite.config.ts")

      this.ctx.viewRegistry.register("{{name}}", viewRoot, configFile)

      return () => {
        this.ctx.viewRegistry.unregister("{{name}}")
      }
    })
  }
}

runtime.register({{PascalName}}ViewService, (import.meta as any).hot)
