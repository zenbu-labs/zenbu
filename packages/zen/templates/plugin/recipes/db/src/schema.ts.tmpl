import zod from "zod"
import { createSchema, f, type InferSchema, type InferRoot } from "#zenbu/kyju/schema"

/**
 * Kyju schema for the "{{name}}" section. Everything under here lands at
 * `root.plugin["{{name}}"]` in the reactive DB.
 *
 * After editing, run `zen kyju generate` from this plugin's directory to
 * produce a migration, then `zen link` to refresh registry types.
 */
export const {{camelName}}Schema = createSchema({
  exampleCount: f.number().default(0),
  notes: f.array(zod.string()).default([]),
})

export const schema = {{camelName}}Schema
export type {{PascalName}}Schema = InferSchema<typeof {{camelName}}Schema>
export type SchemaRoot = InferRoot<{{PascalName}}Schema>
