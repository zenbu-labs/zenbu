import { Service, runtime } from "#zenbu/init/src/main/runtime"
import { DbService } from "#zenbu/init/src/main/services/db"

/**
 * {{PascalName}}Service — your plugin's entry point on the main process.
 *
 * Every public method here is automatically exposed over RPC as
 * `rpc["{{name}}"].<methodName>(...)` after running `zen link`.
 *
 * Edit this file and dynohot will hot-swap the service without restarting.
 */
export class {{PascalName}}Service extends Service {
  static key = "{{name}}"
  static deps = { db: DbService }
  declare ctx: { db: DbService }

  /** Callable over RPC from any view or the CLI. */
  async ping(message: string) {
    return { pong: message, at: Date.now() }
  }

  evaluate() {
    console.log("[{{name}}] service ready")
  }
}

runtime.register({{PascalName}}Service, (import.meta as any).hot)
